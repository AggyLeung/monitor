{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IncidentEvent",
  "type": "object",
  "required": ["incident_id", "status", "created_at", "timeline"],
  "properties": {
    "incident_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["open", "remediating", "verifying", "resolved", "investigating"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "alert": { "$ref": "alert.json" },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["at", "event"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "event": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
